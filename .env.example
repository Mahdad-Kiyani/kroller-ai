# ---- App ----
NODE_ENV=development
PORT=3000
# Service-to-service API key (panel/portal send it as: x-api-key)
SERVICE_API_KEY=dev-service-key-change-me
# Browser origins allowed to call this API (comma-separated). Defaults to the ai-console dev/preview ports.
# CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# ---- Database (PostgreSQL 16 + pgvector) ----
DATABASE_URL="postgresql://wi:wi@localhost:5434/wi_ai?schema=public"

# ---- Redis (BullMQ) ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Object storage (SeaweedFS — S3-compatible) ----
STORAGE_ENDPOINT=http://localhost:8333
STORAGE_REGION=us-east-1
STORAGE_BUCKET=wi-documents
STORAGE_ACCESS_KEY=seaweedadmin
STORAGE_SECRET_KEY=seaweedadmin
STORAGE_FORCE_PATH_STYLE=true

# ---- AI: Anthropic Claude (parse / categorise / exclusion / suggest) ----
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_BASE_URL=https://api.anthropic.com
# CLAUDE_TIMEOUT_MS=180000
# SPA parsing chunking: large documents are split on line boundaries and classified in parallel
# so a single request can't time out or truncate its JSON output. Chunk count scales with SPA size.
# CLAUDE_PARSE_CHUNK_CHARS=12000     # target chars per chunk (0 = never chunk, one request)
# CLAUDE_PARSE_MAX_CONCURRENCY=5     # chunk requests in flight at once
# CLAUDE_PARSE_MAX_TOKENS=8192       # max output tokens per chunk request

# ---- Embeddings (OpenAI-compatible /v1/embeddings endpoint) ----
# EMBEDDINGS_BASE_URL=https://api.openai.com
# EMBEDDINGS_API_KEY=sk-xxxxx
# EMBEDDINGS_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536
